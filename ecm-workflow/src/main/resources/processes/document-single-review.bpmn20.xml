<?xml version="1.0" encoding="UTF-8"?>
<!--
  Document Single Review Process
  ================================
  process key: document-single-review

  Flow:
    Start → Review Task (assigned to candidateGroup) → Gateway → Approved End
                                                               ↘ Rejected End
                                                               ↘ Loop back (REQUEST_INFO)

  Process variables expected at start:
    documentId    (String)  — ECM document UUID
    documentName  (String)  — human-readable name for task description
    candidateGroup (String) — Flowable candidate group key, e.g.:
                              "ECM_BACKOFFICE", "ECM_REVIEWER", "group:3"
    startedBy     (String)  — Okta subject of the person who triggered the workflow
    instanceRecordId (String) — UUID of our WorkflowInstanceRecord

  Process variables set on task completion:
    decision   (String)  — APPROVED | REJECTED | REQUEST_INFO
    comment    (String)  — reviewer comment (required for REJECTED)
    reviewedBy (String)  — Okta subject of the reviewer
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://ecm.com/workflow">

    <process id="document-single-review"
             name="Document Single Review"
             isExecutable="true">

        <!-- Start event -->
        <startEvent id="start" name="Document Submitted">
            <documentation>
                Triggered either automatically (category mapping) or manually
                by the document uploader selecting a workflow.
            </documentation>
        </startEvent>

        <sequenceFlow id="flow-start-to-review" sourceRef="start" targetRef="reviewTask"/>

        <!-- User task: assigned to the candidateGroup process variable -->
        <userTask id="reviewTask"
                  name="Review Document"
                  flowable:candidateGroups="${candidateGroup}">
            <documentation>
                Review document '${documentName}' and make an approval decision.
                Decision must be one of: APPROVED, REJECTED, REQUEST_INFO.
            </documentation>
            <!-- Task listener: fires when task is created — used for notifications -->
            <extensionElements>
                <flowable:taskListener event="create"
                                       delegateExpression="${taskCreatedListener}"/>
                <flowable:taskListener event="complete"
                                       delegateExpression="${taskCompletedListener}"/>
            </extensionElements>
        </userTask>

        <sequenceFlow id="flow-review-to-gateway" sourceRef="reviewTask" targetRef="decisionGateway"/>

        <!-- Exclusive gateway: routes based on the 'decision' variable -->
        <exclusiveGateway id="decisionGateway" name="Review Decision"/>

        <!-- Approved path -->
        <sequenceFlow id="flow-to-approved" sourceRef="decisionGateway" targetRef="approvedEnd">
            <conditionExpression xsi:type="tFormalExpression">
                ${decision == 'APPROVED'}
            </conditionExpression>
        </sequenceFlow>

        <!-- Rejected path -->
        <sequenceFlow id="flow-to-rejected" sourceRef="decisionGateway" targetRef="rejectedEnd">
            <conditionExpression xsi:type="tFormalExpression">
                ${decision == 'REJECTED'}
            </conditionExpression>
        </sequenceFlow>

        <!-- Request more info: loops back to a new review task -->
        <sequenceFlow id="flow-to-info-task" sourceRef="decisionGateway" targetRef="requestInfoTask">
            <conditionExpression xsi:type="tFormalExpression">
                ${decision == 'REQUEST_INFO'}
            </conditionExpression>
        </sequenceFlow>

        <!-- Info request task: assigned back to the original submitter (startedBy) -->
        <userTask id="requestInfoTask"
                  name="Provide Additional Information"
                  flowable:assignee="${startedBy}">
            <documentation>
                Reviewer has requested additional information for document '${documentName}'.
                Please provide the requested information: ${comment}
            </documentation>
            <extensionElements>
                <flowable:taskListener event="create"
                                       delegateExpression="${taskCreatedListener}"/>
                <flowable:taskListener event="complete"
                                       delegateExpression="${taskCompletedListener}"/>
            </extensionElements>
        </userTask>

        <!-- After submitter provides info, go back to reviewer -->
        <sequenceFlow id="flow-info-back-to-review"
                      sourceRef="requestInfoTask"
                      targetRef="reviewTask"/>

        <!-- End events -->
        <endEvent id="approvedEnd" name="Document Approved">
            <extensionElements>
                <flowable:executionListener event="start"
                                            delegateExpression="${processCompletedListener}"/>
            </extensionElements>
        </endEvent>

        <endEvent id="rejectedEnd" name="Document Rejected">
            <extensionElements>
                <flowable:executionListener event="start"
                                            delegateExpression="${processCompletedListener}"/>
            </extensionElements>
        </endEvent>

    </process>

</definitions>
