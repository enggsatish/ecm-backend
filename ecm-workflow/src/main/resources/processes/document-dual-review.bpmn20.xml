<?xml version="1.0" encoding="UTF-8"?>
<!--
  Document Dual Review Process
  ==============================
  process key: document-dual-review

  Flow:
    Start → Step 1: Triage (ECM_BACKOFFICE)
                  → PASS → Step 2: Specialist Review (candidateGroup e.g. Underwriting Team)
                         → APPROVED End
                         → REJECTED End
                         → REQUEST_INFO → loop to Step 2
                  → REJECT Early → Rejected End

  Process variables at start: same as single-review + candidateGroup for Step 2.
  Step 1 (triage) always assigned to ECM_BACKOFFICE role.
  Step 2 assigned to candidateGroup variable.
-->
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="http://ecm.com/workflow">

    <process id="document-dual-review"
             name="Document Dual Review"
             isExecutable="true">

        <startEvent id="start" name="Document Submitted"/>

        <sequenceFlow id="f1" sourceRef="start" targetRef="triageTask"/>

        <!-- Step 1: Backoffice triage — always ECM_BACKOFFICE -->
        <userTask id="triageTask"
                  name="Triage Document"
                  flowable:candidateGroups="ECM_BACKOFFICE">
            <documentation>
                Initial triage of document '${documentName}'.
                Confirm it is complete and route to the appropriate specialist.
                Decision: PASS (route to specialist) or REJECTED (reject immediately).
            </documentation>
            <extensionElements>
                <flowable:taskListener event="create"
                                       delegateExpression="${taskCreatedListener}"/>
                <flowable:taskListener event="complete"
                                       delegateExpression="${taskCompletedListener}"/>
            </extensionElements>
        </userTask>

        <sequenceFlow id="f2" sourceRef="triageTask" targetRef="triageGateway"/>

        <exclusiveGateway id="triageGateway" name="Triage Decision"/>

        <!-- Triage passed: proceed to specialist -->
        <sequenceFlow id="f3" sourceRef="triageGateway" targetRef="specialistTask">
            <conditionExpression xsi:type="tFormalExpression">
                ${decision == 'PASS'}
            </conditionExpression>
        </sequenceFlow>

        <!-- Triage rejected: end immediately -->
        <sequenceFlow id="f4" sourceRef="triageGateway" targetRef="rejectedEnd">
            <conditionExpression xsi:type="tFormalExpression">
                ${decision == 'REJECTED'}
            </conditionExpression>
        </sequenceFlow>

        <!-- Step 2: Specialist review — assigned to candidateGroup variable -->
        <userTask id="specialistTask"
                  name="Specialist Review"
                  flowable:candidateGroups="${candidateGroup}">
            <documentation>
                Specialist review of document '${documentName}'.
                This document passed initial triage.
                Triage notes: ${comment}
            </documentation>
            <extensionElements>
                <flowable:taskListener event="create"
                                       delegateExpression="${taskCreatedListener}"/>
                <flowable:taskListener event="complete"
                                       delegateExpression="${taskCompletedListener}"/>
            </extensionElements>
        </userTask>

        <sequenceFlow id="f5" sourceRef="specialistTask" targetRef="specialistGateway"/>

        <exclusiveGateway id="specialistGateway" name="Specialist Decision"/>

        <sequenceFlow id="f6" sourceRef="specialistGateway" targetRef="approvedEnd">
            <conditionExpression xsi:type="tFormalExpression">${decision == 'APPROVED'}</conditionExpression>
        </sequenceFlow>
        <sequenceFlow id="f7" sourceRef="specialistGateway" targetRef="rejectedEnd">
            <conditionExpression xsi:type="tFormalExpression">${decision == 'REJECTED'}</conditionExpression>
        </sequenceFlow>
        <sequenceFlow id="f8" sourceRef="specialistGateway" targetRef="requestInfoTask">
            <conditionExpression xsi:type="tFormalExpression">${decision == 'REQUEST_INFO'}</conditionExpression>
        </sequenceFlow>

        <!-- Info request: submitter provides additional info -->
        <userTask id="requestInfoTask"
                  name="Provide Additional Information"
                  flowable:assignee="${startedBy}">
            <documentation>Additional info requested: ${comment}</documentation>
            <extensionElements>
                <flowable:taskListener event="create"
                                       delegateExpression="${taskCreatedListener}"/>
                <flowable:taskListener event="complete"
                                       delegateExpression="${taskCompletedListener}"/>
            </extensionElements>
        </userTask>

        <sequenceFlow id="f9" sourceRef="requestInfoTask" targetRef="specialistTask"/>

        <endEvent id="approvedEnd" name="Document Approved">
            <extensionElements>
                <flowable:executionListener event="start"
                                            delegateExpression="${processCompletedListener}"/>
            </extensionElements>
        </endEvent>

        <endEvent id="rejectedEnd" name="Document Rejected">
            <extensionElements>
                <flowable:executionListener event="start"
                                            delegateExpression="${processCompletedListener}"/>
            </extensionElements>
        </endEvent>

    </process>

</definitions>
